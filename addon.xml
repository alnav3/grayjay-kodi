<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.grayjay"
       name="Grayjay"
       version="0.1.0"
       provider-name="grayjay-kodi">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.22.0" optional="true"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Grayjay sources for Kodi</summary>
        <description lang="en_GB">Runs Grayjay JavaScript source plugins inside Kodi. Follow creators across platforms using the same community source plugins as the Grayjay app. Experimental.</description>
        <platform>all</platform>
        <license>See LICENSE.md</license>
        <source>https://github.com/grayjay-kodi/grayjay-kodi</source>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.png</fanart>
        </assets>
    </extension>
</addon>
